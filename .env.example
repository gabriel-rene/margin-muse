# Copy this file to .env.local and configure a muse provider.
# .env.local is gitignored and is read only on the server — nothing here is
# ever sent to the browser. The muse call lives in app/api/muse/route.ts.

# Which backend answers muse pulls: gemini (hosted) | ollama | lmstudio (local)
MUSE_PROVIDER=gemini

# --- gemini (default) ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# --- local models (no API key, nothing leaves your machine) ---
# ollama:   `ollama serve` + `ollama pull llama3.2`  (default port 11434)
# lmstudio: load a model and start the local server    (default port 1234)
#
# MUSE_PROVIDER=ollama
# MUSE_MODEL=llama3.2                     # model tag (ollama) or name (lmstudio); optional
# MUSE_LOCAL_URL=http://localhost:11434   # override only for non-default ports
