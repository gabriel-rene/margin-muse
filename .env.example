# Copy this file to .env.local and fill in your key.
# .env.local is gitignored and is read only on the server — the key is never
# sent to the browser. The muse calls the Anthropic API from app/api/muse/route.ts.
#
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here
